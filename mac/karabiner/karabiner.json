{
    "global": { "show_in_menu_bar": false },
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "hyper-shift-s → unstack window",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "s",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/yabai -m window --toggle float && /opt/homebrew/bin/yabai -m window --toggle float" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "hyper-s → insert window into stack",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "s",
                                    "modifiers": { "mandatory": ["command", "option", "control"] }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/yabai -m window --insert stack" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "hyper+shift+] / hyper+shift+[ → move window forward/backward in stack",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "close_bracket",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/yabai -m window --stack next" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "open_bracket",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/yabai -m window --stack prev" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "hyper-[ / hyper-] → cycle yabai stack with wrap-around",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "open_bracket",
                                    "modifiers": { "mandatory": ["command", "option", "control"] }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/yabai -m window --focus stack.prev || /opt/homebrew/bin/yabai -m window --focus stack.last || /opt/homebrew/bin/yabai -m window --focus prev || /opt/homebrew/bin/yabai -m window --focus last" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "close_bracket",
                                    "modifiers": { "mandatory": ["command", "option", "control"] }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/yabai -m window --focus stack.next || /opt/homebrew/bin/yabai -m window --focus stack.first || /opt/homebrew/bin/yabai -m window --focus next || /opt/homebrew/bin/yabai -m window --focus first" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "hyper-shift-f → toggle floating (i3: floating toggle)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "f",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/yabai -m window --toggle float" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "hyper-f → toggle yabai fullscreen (i3: fullscreen toggle)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "f",
                                    "modifiers": { "mandatory": ["command", "option", "control"] }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/yabai -m window --toggle zoom-fullscreen" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "hyper-backspace → toggle split orientation (i3: split toggle)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "delete_or_backspace",
                                    "modifiers": { "mandatory": ["command", "option", "control"] }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/yabai -m window --toggle split" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "hyper-g → set split horizontal (only toggles if needed)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "g",
                                    "modifiers": { "mandatory": ["command", "option", "control"] }
                                },
                                "to": [{ "shell_command": "st=$(/opt/homebrew/bin/yabai -m query --windows --window | /opt/homebrew/bin/jq -r '.split_type // \"none\"'); if [ \"$st\" = \"vertical\" ]; then /opt/homebrew/bin/yabai -m window --toggle split; fi" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "hyper-v → set split vertical (only toggles if needed)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "v",
                                    "modifiers": { "mandatory": ["command", "option", "control"] }
                                },
                                "to": [{ "shell_command": "st=$(/opt/homebrew/bin/yabai -m query --windows --window | /opt/homebrew/bin/jq -r '.split_type // \"none\"'); if [ \"$st\" = \"horizontal\" ]; then /opt/homebrew/bin/yabai -m window --toggle split; fi" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "hyper-shift-t → focus mode toggle (i3: focus mode_toggle between floating vs tiled)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "t",
                                    "modifiers": { "mandatory": ["command", "option", "control", "shift"] }
                                },
                                "to": [{ "shell_command": "isfloat=$(/opt/homebrew/bin/yabai -m query --windows --window | /opt/homebrew/bin/jq -r '.floating'); if [ \"$isfloat\" = \"1\" ]; then id=$(/opt/homebrew/bin/yabai -m query --windows --space | /opt/homebrew/bin/jq 'map(select(.floating==0)) | .[0].id // empty'); [ -n \"$id\" ] && /opt/homebrew/bin/yabai -m window --focus \"$id\"; else id=$(/opt/homebrew/bin/yabai -m query --windows --space | /opt/homebrew/bin/jq 'map(select(.floating==1)) | .[0].id // empty'); [ -n \"$id\" ] && /opt/homebrew/bin/yabai -m window --focus \"$id\"; fi" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "hyper-t → workspace layout cycle (bsp → stack → float → bsp) (i3: layout toggle)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "t",
                                    "modifiers": { "mandatory": ["command", "option", "control"] }
                                },
                                "to": [{ "shell_command": "cur=$(/opt/homebrew/bin/yabai -m query --spaces --space | /usr/bin/jq -r '.type'); case \"$cur\" in bsp)   /opt/homebrew/bin/yabai -m space --layout stack ;; stack) /opt/homebrew/bin/yabai -m space --layout float ;; float) /opt/homebrew/bin/yabai -m space --layout bsp ;; esac" }],
                                "type": "basic"
                            }
                        ]
                    },
